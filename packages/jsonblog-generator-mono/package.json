{
  "name": "jsonblog-generator-mono",
  "version": "0.2.0",
  "description": "Warm paper, serif prose, mono UI — a subtle engineering theme for JSON Blog",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "jsonblog",
    "blog",
    "generator",
    "static-site",
    "markdown",
    "monospace",
    "minimal"
  ],
  "author": "Thomas Davis <thomasalwyndavis@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "handlebars": "^4.7.8",
    "markdown-it": "^14.0.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "rss": "^1.2.2",
    "slugify": "^1.6.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
