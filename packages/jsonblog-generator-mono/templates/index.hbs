{{#> layout}}
  {{#*inline "content"}}
    {{#if posts}}
      <div class="log-head">
        <span>// posts.log</span>
        <span>{{posts.length}} entries{{#if pagination}}{{#if (gt pagination.totalPages 1)}} · page {{pagination.currentPage}}/{{pagination.totalPages}}{{/if}}{{/if}}</span>
      </div>

      <ul class="log">
        {{#each posts}}
          <li class="log-entry">
            <span class="log-date">{{#if this.createdAt}}{{formatDate this.createdAt}}{{else}}----------{{/if}}</span>
            <span class="log-tag">{{#if (eq this.type 'ai')}}[AI]{{else if this.categories}}[{{this.categories.[0]}}]{{else}}[post]{{/if}}</span>
            <span class="log-title"><a href="/{{this.slug}}">{{this.title}}</a></span>
          </li>
        {{/each}}
      </ul>

      {{#if pagination}}
        {{#if (gt pagination.totalPages 1)}}
          <nav class="pagination">
            {{#if pagination.hasPrev}}
              {{#if pagination.isFirstPage}}
                <a href="/">&lt;- prev</a>
              {{else}}
                <a href="/page/{{pagination.prevPage}}">&lt;- prev</a>
              {{/if}}
            {{else}}
              <button disabled>&lt;- prev</button>
            {{/if}}

            <span class="pgr">[{{pagination.currentPage}}/{{pagination.totalPages}}]</span>

            {{#if pagination.hasNext}}
              <a href="/page/{{pagination.nextPage}}">next -&gt;</a>
            {{else}}
              <button disabled>next -&gt;</button>
            {{/if}}
          </nav>
        {{/if}}
      {{/if}}
    {{else}}
      <p style="color:var(--muted)">// no posts yet</p>
    {{/if}}
  {{/inline}}
{{/layout}}
