{{#> layout}}
  {{#*inline "content"}}
    {{#if posts}}
      <div class="log-head">
        <span>writing</span>
        <span>{{posts.length}}{{#if pagination}}{{#if (gt pagination.totalPages 1)}} · {{pagination.currentPage}}/{{pagination.totalPages}}{{/if}}{{/if}}</span>
      </div>

      <ul class="log">
        {{#each posts}}
          <li class="log-entry">
            <span class="log-date">{{#if this.createdAt}}{{formatDate this.createdAt}}{{else}}—{{/if}}</span>
            <span class="log-title">
              <a href="/{{this.slug}}">{{this.title}}</a>
              {{#if (eq this.type 'ai')}}<span class="log-tag">ai</span>{{else if this.categories}}<span class="log-tag">{{this.categories.[0]}}</span>{{/if}}
            </span>
          </li>
        {{/each}}
      </ul>

      {{#if pagination}}
        {{#if (gt pagination.totalPages 1)}}
          <nav class="pagination">
            {{#if pagination.hasPrev}}
              {{#if pagination.isFirstPage}}
                <a href="/">← newer</a>
              {{else}}
                <a href="/page/{{pagination.prevPage}}">← newer</a>
              {{/if}}
            {{else}}
              <button disabled>← newer</button>
            {{/if}}

            <span class="pgr">{{pagination.currentPage}} of {{pagination.totalPages}}</span>

            {{#if pagination.hasNext}}
              <a href="/page/{{pagination.nextPage}}">older →</a>
            {{else}}
              <button disabled>older →</button>
            {{/if}}
          </nav>
        {{/if}}
      {{/if}}
    {{else}}
      <p style="color:var(--muted); font-style:italic">No posts yet.</p>
    {{/if}}
  {{/inline}}
{{/layout}}
