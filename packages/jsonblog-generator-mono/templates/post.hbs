{{#> layout}}
  {{#*inline "content"}}
    <article class="post">
      <div class="post-frontmatter">
        <span class="kv"><span class="k">title</span>    :: {{post.title}}</span>
        {{~#if post.createdAt~}}<span class="kv"><span class="k">date</span>     :: {{formatDate post.createdAt}}</span>{{~/if~}}
        {{~#if post.type~}}<span class="kv"><span class="k">type</span>     :: {{post.type}}</span>{{~/if~}}
        {{~#if post.categories~}}<span class="kv"><span class="k">category</span> :: {{post.categories.[0]}}</span>{{~/if~}}
        {{~#if post.tags~}}<span class="kv"><span class="k">tags</span>     :: {{#each post.tags}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</span>{{~/if~}}
      </div>

      <h1 class="post-title">{{post.title}}</h1>

      <div class="content">
        {{{post.content}}}
      </div>

      {{#if post.tags}}
        <div class="tags">
          {{#each post.tags}}<a href="/tag/{{slugify this}}" class="tag">#{{this}}</a>{{/each}}
        </div>
      {{/if}}

      <a href="/" class="back">&lt;- back to index</a>
    </article>
  {{/inline}}
{{/layout}}
